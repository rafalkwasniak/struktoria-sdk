    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/rafalkwasniak/struktoria-sdk",
    "keywords": ["struktoria", "agidot", "sdk", "rag", "documents", "api-client"],
    "authors": [
        {
            "name": "Rafal Kwasniak",
            "email": "rafal@kwasniak.org"
        }
    ],
    "require": {
        "php": "^8.0",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "autoload": {
        "psr-4": {
